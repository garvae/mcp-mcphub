{
  "name": "@garvae/mcp-mcphub",
  "description": "Typed, profile-gated MCP server for managing MCPHub instances through the MCPHub REST Management API",
  "version": "1.0.1",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22.13 <25"
  },
  "bin": {
    "mcp-mcphub": "dist/cli/bin.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": "./dist/cli/bin.js"
  },
  "files": [
    "assets/readme",
    "dist",
    "docs",
    ".env.example",
    "AGENTS.md",
    "docker-compose.example.yml",
    "CHANGELOG.md",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "LICENSE",
    "README.md",
    "ROADMAP.md",
    "SECURITY.md",
    "SUPPORT.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/garvae/mcp-mcphub.git"
  },
  "homepage": "https://github.com/garvae/mcp-mcphub#readme",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/garvae"
  },
  "bugs": {
    "url": "https://github.com/garvae/mcp-mcphub/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mcp-server",
    "mcphub",
    "management",
    "mcphub-management",
    "automation",
    "ai-agents",
    "agent-ops",
    "claude",
    "codex",
    "community",
    "developer-tools",
    "infrastructure",
    "streamable-http",
    "stdio",
    "openapi",
    "nodejs"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsx scripts/copy-runtime-fixtures.ts",
    "build:clean": "rimraf dist && pnpm build",
    "changeset": "changeset",
    "cleanup:real-fixtures": "tsx scripts/cleanup-real-fixtures.ts",
    "compatibility:sync-targets": "tsx scripts/sync-compatibility-targets.ts",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "docs:compatibility": "tsx scripts/update-compatibility.ts",
    "docs:compatibility:check": "tsx scripts/update-compatibility.ts --check",
    "docs:coverage": "tsx scripts/update-coverage.ts",
    "docs:coverage:check": "tsx scripts/update-coverage.ts --check",
    "docs:tools": "tsx scripts/update-tools-docs.ts",
    "docs:tools:check": "tsx scripts/update-tools-docs.ts --check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "pack:validate": "tsx scripts/audit-package.ts --pack",
    "publish:dry-run": "pnpm publish --dry-run --no-git-checks",
    "release": "pnpm publish --no-git-checks",
    "test": "vitest run",
    "test:coverage": "vitest run -c vitest.coverage.config.ts",
    "test:compatibility": "vitest run -c vitest.integration.config.ts tests/integration/upstream-compat.test.ts",
    "test:watch": "vitest",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "test:package:installed": "pnpm build:clean && pnpm pack:validate && vitest run -c vitest.package.config.ts",
    "test:coverage-matrix": "tsx scripts/verify-coverage.ts",
    "test:real": "vitest run -c vitest.real.config.ts",
    "test:real:doctor": "vitest run -c vitest.real.config.ts tests/real/doctor-live.test.ts",
    "test:real:http": "vitest run -c vitest.real.config.ts tests/real/http-live.test.ts",
    "test:real:mutation": "vitest run -c vitest.real.config.ts tests/real/mutation-live.test.ts",
    "test:real:readonly": "vitest run -c vitest.real.config.ts tests/real/doctor-live.test.ts tests/real/stdio-live.test.ts tests/real/http-live.test.ts tests/real/safe-live.test.ts",
    "test:real:safe": "vitest run -c vitest.real.config.ts tests/real/safe-live.test.ts",
    "test:real:stdio": "vitest run -c vitest.real.config.ts tests/real/stdio-live.test.ts",
    "snapshot:routes": "tsx scripts/fetch-routes-snapshot.ts",
    "doctor": "node dist/cli/bin.js doctor",
    "version:packages": "changeset version"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "undici": "^8.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.6",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.9",
    "msw": "^2.14.6",
    "prettier": "^3.8.4",
    "rimraf": "^6.1.3",
    "testcontainers": "12.0.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
