# =============================================================================
# Platform Infrastructure Monorepo — .gitignore
# Optimized for Turborepo + pnpm workspaces + Node.js
# =============================================================================


# =============================================================================
# Dependencies
# =============================================================================
node_modules/
.pnp
.pnp.js
.pnp.cjs


# =============================================================================
# Turborepo
# =============================================================================
# Turbo remote cache artifacts
.turbo/
# Per-package turbo cache (generated by turbo run)
**/.turbo/


# =============================================================================
# Build Outputs
# =============================================================================
dist/
build/
out/
.output/


# =============================================================================
# Test & Coverage
# =============================================================================
coverage/
!src/core/coverage/
!src/core/coverage/**
.nyc_output/
*.lcov
junit.xml
test-results/
playwright-report/
playwright/.cache/
.vitest-cache/
reports/
.stryker-tmp/


# =============================================================================
# TypeScript
# =============================================================================
# Incremental compilation cache
*.tsbuildinfo


# =============================================================================
# Environment & Secrets
# =============================================================================
.env
.env.*
!.env.example
!.env.*.example
.runtime/
.secrets/
*.pem
*.key
*.p12
*.pfx


# =============================================================================
# Logs
# =============================================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*


# =============================================================================
# OS & Editor Files
# =============================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# JetBrains IDEs
.idea/
*.iml
*.iws
*.ipr

# VS Code (keep .vscode/extensions.json and .vscode/settings.json if checked in intentionally)
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json

# Vim/Neovim swap files
*.swp
*.swo
*.swn
[._]*.s[a-v][a-z]
[._]*.sw[a-p]

# Emacs backup files
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock


# =============================================================================
# Package Managers
# =============================================================================
# Only one lock file should be committed — pnpm-lock.yaml for this repo
package-lock.json
yarn.lock
# Keep pnpm-lock.yaml (committed)
# pnpm-lock.yaml


# =============================================================================
# Docker
# =============================================================================
.docker/
backups/
.artifacts/

# =============================================================================
# Miscellaneous
# =============================================================================

# Temp files
tmp/
temp/
*.tmp
*.temp
*.bak
.aider*
google-inventory.json


# =============================================================================
# Graphify generated output
# =============================================================================
graphify-out/
src/graphify-out/


# =============================================================================
# Obsidian vault state for docs/
# =============================================================================
# Workspace state is personal and should not be shared
src/.obsidian/
# Plugin runtime data may contain tokens or personal state
docs/.obsidian/plugins/*/data.json
# Obsidian trash
docs/.trash/


# =============================================================================
# Local artifacts
# =============================================================================
# Local Workspace artifacts
.workspace.local
