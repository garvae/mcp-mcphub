# MCPHub Management MCP configuration template
#
# How to use this file:
# 1. Copy it to `.env` or pass it directly with `--config .env.example` after replacing placeholders.
# 2. For the smallest local setup you usually need only the "Required for most users" section.
# 3. Everything else below is optional and already has safe defaults unless a comment says otherwise.
#
# Where values usually come from:
# - MCPHUB_* values come from the upstream MCPHub instance that this server will manage.
# - MCP_HTTP_* values belong to this MCP server itself and are only needed for HTTP mode.
# - ALLOW_* values are local safety switches in this project and default to `false` on purpose.
#
# Recommended first run:
# - local stdio client: set MCPHUB_URL + one upstream credential, then run `mcp-mcphub stdio --exposure=safe`
# - local HTTP server: same as above, plus MCP_HTTP_AUTH_TOKEN, then run `mcp-mcphub http`

# ============================================================================
# Required for most users: connect this MCP server to one upstream MCPHub
# ============================================================================

# Base URL of the MCPHub instance you want to manage.
# What it affects:
# - every management API request sent by this server goes to this base URL.
# Where to get it:
# - from the browser URL where you open MCPHub;
# - from the reverse proxy or ingress URL of your MCPHub deployment;
# - from the service URL documented by whoever operates your MCPHub environment.
# Typical example:
# - https://mcphub-site.com
MCPHUB_URL="https://mcphub-site.com"

# Upstream credential used by this MCP server to authenticate to MCPHub.
# What it affects:
# - determines whether this server can call MCPHub management endpoints.
# Where to get it:
# - usually create a bearer key or system token inside MCPHub admin/settings UI;
# - or obtain it from your secret manager / deployment platform if ops already created it.
# For local first run:
# - use a dedicated automation token, not a personal browser session token.
MCPHUB_TOKEN="REPLACE_ME"

# Type of upstream credential.
# Allowed values:
# - bearer: static bearer token or API key
# - jwt: login flow with MCPHUB_USERNAME + MCPHUB_PASSWORD
# - oauth: client-credentials style access token
# - better-auth: forward an existing MCPHub Better Auth cookie
# What most users need:
# - keep `bearer`
MCPHUB_TOKEN_KIND="bearer"

# HTTP header used when authenticating to upstream MCPHub.
# Allowed values:
# - Authorization
# - x-auth-token
# What most users need:
# - keep `Authorization`
# Where to confirm:
# - check how your MCPHub deployment expects API tokens;
# - if unsure, start with Authorization.
MCPHUB_AUTH_HEADER="Authorization"

# ============================================================================
# Optional upstream authentication alternatives
# Use these only if you are NOT using a simple static bearer token.
# ============================================================================

# Username for upstream JWT login mode.
# Needed only when:
# - MCPHUB_TOKEN_KIND=jwt
# Where to get it:
# - the MCPHub account username/email used for admin login.
# Leave unset for bearer-token setups.
# MCPHUB_USERNAME="admin@example.com"

# Password for upstream JWT login mode.
# Needed only when:
# - MCPHUB_TOKEN_KIND=jwt
# Where to get it:
# - the password for the upstream MCPHub account above.
# Security note:
# - prefer a dedicated service account if you must use this mode.
# MCPHUB_PASSWORD="REPLACE_ME"

# OAuth client id for upstream OAuth client-credentials mode.
# Needed only when:
# - MCPHUB_TOKEN_KIND=oauth
# Where to get it:
# - from your OAuth provider or from MCPHub-side OAuth client registration.
# MCPHUB_OAUTH_CLIENT_ID="mcphub-management-mcp"

# OAuth client secret for upstream OAuth client-credentials mode.
# Needed only when:
# - MCPHUB_TOKEN_KIND=oauth
# Where to get it:
# - from the same OAuth client registration as MCPHUB_OAUTH_CLIENT_ID.
# MCPHUB_OAUTH_CLIENT_SECRET="REPLACE_ME"

# OAuth token endpoint for upstream OAuth mode.
# Needed only when:
# - MCPHUB_TOKEN_KIND=oauth
# Where to get it:
# - from your identity provider or MCPHub OAuth setup documentation.
# Example:
# - https://mcphub-site.com/oauth/token
# MCPHUB_OAUTH_TOKEN_URL="https://mcphub-site.com/oauth/token"

# Optional OAuth scope requested from the upstream token endpoint.
# Needed only when:
# - MCPHUB_TOKEN_KIND=oauth and your provider requires explicit scopes.
# Where to get it:
# - from your IdP or OAuth client configuration.
# MCPHUB_OAUTH_SCOPE="mcphub:admin"

# Better Auth cookie for upstream MCPHub.
# Needed only when:
# - MCPHUB_TOKEN_KIND=better-auth
# Where to get it:
# - from an already-authenticated MCPHub browser session if you intentionally allow session passthrough.
# Operational note:
# - this is not the recommended default for unattended automation.
# MCPHUB_BETTER_AUTH_COOKIE="session=REPLACE_ME"

# JSON object for managing multiple upstream MCPHub instances from one server.
# Use this instead of plain MCPHUB_URL + MCPHUB_TOKEN when:
# - one MCP server should switch between several MCPHub environments such as primary/staging.
# Where to get values:
# - each profile needs its own URL and credentials that you would otherwise place in the flat MCPHUB_* vars.
# Example shape:
# - {"primary":{"url":"https://mcphub-primary.example.com","tokenEnv":"MCPHUB_PRIMARY_TOKEN","tokenKind":"bearer","authHeader":"Authorization"}}
# Note:
# - tokenEnv means the real secret is stored in another environment variable, not inline here.
# MCPHUB_PROFILES_JSON='{"primary":{"url":"https://mcphub-primary.example.com","tokenEnv":"MCPHUB_PRIMARY_TOKEN","tokenKind":"bearer","authHeader":"Authorization"}}'

# Default upstream profile name used when MCPHUB_PROFILES_JSON defines multiple profiles.
# What most users need:
# - ignore this unless you use MCPHUB_PROFILES_JSON.
# MCPHUB_DEFAULT_PROFILE="default"

# ============================================================================
# Optional request tuning for upstream API calls
# Safe to leave at defaults for normal use.
# ============================================================================

# Timeout for one upstream MCPHub HTTP request in milliseconds.
# Increase only if your MCPHub instance is slow or sits behind high-latency infrastructure.
MCPHUB_REQUEST_TIMEOUT_MS="30000"

# Number of retry attempts for transient upstream request failures.
# What most users need:
# - keep the default.
MCPHUB_REQUEST_RETRY_ATTEMPTS="2"

# Backoff delay between retries in milliseconds.
# What most users need:
# - keep the default.
MCPHUB_REQUEST_RETRY_BACKOFF_MS="250"

# ============================================================================
# Optional MCP exposure defaults
# These shape what this MCP server exposes to clients.
# ============================================================================

# Default exposure profile for stdio mode.
# Allowed values:
# - safe, ops, admin, all
# What most users need:
# - start with safe
# Why:
# - safe gives read-only diagnostics and inventory tools.
MCP_DEFAULT_EXPOSURE="safe"

# Which HTTP endpoints this server should expose in HTTP mode.
# Comma-separated list of profiles.
# Default:
# - safe,ops,admin,all
# Example:
# - set to `safe,admin` if you only want those two endpoints exposed over HTTP.
MCP_EXPOSE_ENDPOINTS="safe,ops,admin,all"

# Force all tools into read-only behavior where supported, even on elevated profiles.
# Useful when:
# - you want to harden a debugging environment.
# What most users need:
# - leave false.
# MCP_FORCE_READONLY="false"

# Redact secrets from tool output and logs.
# What most users need:
# - leave true.
MCP_REDACT_SECRETS="true"

# Logging level for this MCP server.
# Allowed values:
# - debug, info, warn, error
# What most users need:
# - keep info
# Change to debug only while troubleshooting.
MCP_LOG_LEVEL="info"

# ============================================================================
# Optional audit logging
# Used when you need a local audit trail of server actions.
# ============================================================================

# Path to an NDJSON audit log written by this MCP server.
# Example:
# - ./logs/audit.ndjson
# Leave unset if you do not want a local audit file.
# MCP_AUDIT_FILE="./logs/audit.ndjson"

# Rotate the audit file after this many bytes.
MCP_AUDIT_MAX_BYTES="1048576"

# Number of rotated audit files to keep.
MCP_AUDIT_MAX_FILES="5"

# ============================================================================
# Optional HTTP transport settings
# Needed only when you run `mcp-mcphub http`.
# ============================================================================

# Local bind host for the HTTP transport of this MCP server.
# What most users need:
# - keep 127.0.0.1 for local-only testing
# Change only when:
# - you intentionally expose the service behind a reverse proxy or container network.
MCP_HTTP_HOST="127.0.0.1"

# Local bind port for the HTTP transport of this MCP server.
# What most users need:
# - keep 7345 unless it conflicts with another local service.
MCP_HTTP_PORT="7345"

# HTTP transport protocol behavior.
# Allowed values:
# - stateful: current SDK-backed streamable HTTP behavior
# - stateless: per-request 2026-07-28 semantics
# What most users need:
# - keep stateful unless you specifically need stateless protocol behavior.
# MCP_HTTP_MODE="stateful"

# How inbound HTTP clients authenticate to this MCP server.
# Allowed values:
# - static: local bearer token map
# - oauth: introspect inbound OAuth tokens
# - better-auth: trust inbound MCPHub Better Auth session cookies
# - hybrid: accept more than one of the above
# What most users need:
# - keep static
# MCP_HTTP_AUTH_MODE="static"

# Smallest static HTTP auth setup for this MCP server itself.
# Required only when:
# - you run `mcp-mcphub http` and one inbound token is enough.
# What it affects:
# - clients must present this token to call your local HTTP MCP endpoint.
# Where the value comes from:
# - you invent and store it yourself; it does not come from upstream MCPHub.
# Exposure granted by default:
# - safe
# MCP_HTTP_AUTH_TOKEN="REPLACE_ME_SAFE_TOKEN"

# Exposure profile granted by MCP_HTTP_AUTH_TOKEN.
# Allowed values:
# - safe, ops, admin, all
# What most users need:
# - keep safe
# MCP_HTTP_AUTH_EXPOSURE="safe"

# Token-to-profile map for HTTP mode.
# Required only when:
# - you run `mcp-mcphub http` with static or hybrid inbound auth and need more than one token,
#   or you need per-token upstream profile mapping.
# What it affects:
# - controls which local HTTP client token can access which exposure profile.
# Where the values come from:
# - you invent and store these tokens yourself; they belong to this MCP server, not to upstream MCPHub.
# Example:
# - {"REPLACE_ME_SAFE_TOKEN":"safe","REPLACE_ME_ADMIN_TOKEN":"admin"}
MCP_HTTP_AUTH_TOKENS_JSON='{"REPLACE_ME_SAFE_TOKEN":"safe"}'

# Allowed Host header values for inbound HTTP requests.
# What most users need:
# - keep localhost values for local testing
# Change this when:
# - you put the server behind a real hostname such as mcp.example.com.
MCP_HTTP_ALLOWED_HOSTS="127.0.0.1,localhost"

# Allowed browser origins for inbound HTTP requests.
# Leave empty when:
# - you do not call the HTTP endpoint directly from a browser.
# Set this when:
# - browser-based clients such as ChatGPT/Claude web surfaces must reach the endpoint.
# Example:
# - https://claude.ai,https://chat.openai.com
MCP_HTTP_ALLOWED_ORIGINS=""

# Maximum inbound HTTP request body size in bytes.
# What most users need:
# - keep the default.
MCP_HTTP_BODY_LIMIT="1048576"

# ============================================================================
# Optional inbound OAuth introspection settings
# Needed only when MCP_HTTP_AUTH_MODE=oauth or hybrid with OAuth enabled.
# ============================================================================

# Introspection endpoint used to validate inbound HTTP client access tokens.
# Required when:
# - MCP_HTTP_AUTH_MODE=oauth
# - MCP_HTTP_AUTH_MODE=hybrid and you expect OAuth tokens
# Where to get it:
# - from your identity provider or API gateway documentation.
# MCP_HTTP_OAUTH_INTROSPECTION_URL="https://auth.example.com/introspect"

# Optional client id used when this server calls the introspection endpoint.
# Needed only if your auth server requires client authentication for introspection.
# MCP_HTTP_OAUTH_CLIENT_ID="mcphub-management-mcp"

# Optional client secret paired with MCP_HTTP_OAUTH_CLIENT_ID.
# MCP_HTTP_OAUTH_CLIENT_SECRET="REPLACE_ME"

# Optional scope that every introspected inbound token must contain.
# Example:
# - mcphub:admin
# MCP_HTTP_OAUTH_REQUIRED_SCOPE="mcphub:admin"

# Fallback exposure profile if introspection succeeds but does not return a dedicated mcp_profile claim.
# What most users need:
# - keep safe.
# MCP_HTTP_OAUTH_EXPOSURE_FALLBACK="safe"

# Optional upstream MCPHub profile that OAuth-authenticated HTTP clients should use by default.
# Needed only with multi-upstream setups.
# MCP_HTTP_OAUTH_UPSTREAM_PROFILE="primary"

# ============================================================================
# Optional inbound Better Auth bridge settings
# Needed only when MCP_HTTP_AUTH_MODE=better-auth or hybrid.
# ============================================================================

# Exposure granted to inbound Better Auth cookie sessions.
# What most users need:
# - keep safe unless you intentionally trust those browser sessions with more power.
# MCP_HTTP_BETTER_AUTH_EXPOSURE="safe"

# Optional upstream MCPHub profile name used for Better Auth inbound sessions.
# Needed only with multi-upstream setups.
# MCP_HTTP_BETTER_AUTH_UPSTREAM_PROFILE="primary"

# ============================================================================
# Optional mutation allowlist
# Used to narrow which target hosts may appear in upstream server definitions.
# ============================================================================

# Comma-separated allowlist of hostnames allowed in URL-bearing mutation tools.
# Leave empty to use the built-in validation only.
# Set this when:
# - you want to ensure created/updated upstream servers can point only to approved domains.
# Example:
# - api.example.com,registry.internal.example.com
# MCP_ALLOWED_TARGET_HOSTS=""

# ============================================================================
# Optional dangerous feature flags
# All default to false on purpose. Turn them on only if you explicitly need them.
# ============================================================================

# Reserved for future secret-export flows.
# Leave false unless the project later documents a supported export path.
ALLOW_SECRET_EXPORT="false"

# Allows creating/updating upstream MCPHub server definitions that execute local stdio commands.
# Why this is dangerous:
# - it can enable arbitrary command execution paths on systems that trust the resulting MCPHub config.
# Turn on only in tightly controlled environments.
ALLOW_STDIO_SERVER_CREATE="false"

# Allows system configuration write tools.
# Why this is dangerous:
# - these operations can change global MCPHub behavior.
ALLOW_SYSTEM_CONFIG_WRITE="false"

# Enables bearer-key, OAuth-client, and user admin tools.
# Why this is dangerous:
# - these operations manage credentials and identities.
ALLOW_AUTH_ADMIN_TOOLS="false"

# Enables MCPB upload flows.
# Why this is dangerous:
# - bundle uploads may introduce untrusted package content.
ALLOW_MCPB_UPLOAD="false"

# ============================================================================
# Optional repository test-harness variables
# These are NOT required for normal package usage.
# They are only used by local/CI validation commands such as:
# - pnpm test:real:readonly
# - pnpm test:real:mutation
# - pnpm cleanup:real-fixtures
# - manually triggered release workflow live checks
# ============================================================================

# Opt-in switch for live read-only tests against a dedicated MCPHub instance.
# What it affects:
# - enables tests that hit a real MCPHub using the REAL_TEST_* variables below.
# What most users need:
# - leave unset unless you are validating a real test environment.
# RUN_REAL_MCPHUB_TESTS="1"

# Opt-in switch for live mutation tests.
# What it affects:
# - enables tests that create and delete namespaced fixtures on a dedicated test MCPHub.
# Safety rule:
# - never enable this against production.
# RUN_REAL_MCPHUB_MUTATION_TESTS="1"

# Dedicated MCPHub URL used only by the live test harness.
# Why this exists separately from MCPHUB_URL:
# - lets you keep runtime configuration and release-test configuration independent.
# Where to get it:
# - use the base URL of a dedicated test MCPHub instance.
# REAL_TEST_MCPHUB_URL="https://mcphub-test.example.com"

# Dedicated MCPHub management credential used only by the live test harness.
# Where to get it:
# - create a dedicated automation token in the test MCPHub, or obtain it from your secret manager.
# Important:
# - this is an upstream MCPHub token, not a local HTTP token for this MCP package.
# REAL_TEST_MCPHUB_TOKEN="REPLACE_ME"

# Upstream auth mode override for the live test harness.
# What most users need:
# - keep bearer or leave unset.
# REAL_TEST_MCPHUB_TOKEN_KIND="bearer"

# Upstream auth header override for the live test harness.
# Use this only if the test MCPHub expects x-auth-token instead of Authorization.
# REAL_TEST_MCPHUB_AUTH_HEADER="Authorization"

# Optional upstream profile name for live tests in multi-profile setups.
# Use this only if your local config defines MCPHUB_PROFILES_JSON and the tests should target one named profile.
# REAL_TEST_MCPHUB_PROFILE="primary"

# Local bearer token used by the temporary local HTTP MCP server started inside live tests.
# This token belongs to this MCP package test harness, not to upstream MCPHub.
# Where to get it:
# - invent it yourself and store it locally or in CI secrets.
# REAL_TEST_HTTP_AUTH_TOKEN="REPLACE_ME_SAFE_TOKEN"

# Prefix used by live mutation tests and cleanup scripts to identify ephemeral fixture groups.
# What most users need:
# - keep the default or set a unique prefix for CI.
# REAL_TEST_FIXTURE_PREFIX="mcp-mcphub-test"

# Release hardening switch.
# What it affects:
# - when set to 1, the release workflow fails instead of skipping live suites if REAL_TEST_* secrets are missing.
# Use this when:
# - your release policy requires live MCPHub verification before publish.
# RELEASE_REAL_TESTS_REQUIRED="1"
